# ─── Core ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=replace-with-64-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://syntax_user:yourpassword@localhost:5432/syntax_asia_db

# ─── Admin ───────────────────────────────────────────────────────────────────
# Change this from the default to obscure the admin panel from scanners
ADMIN_URL=management-portal/

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=payroll@syntaxasia.lk
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Syntax Asia Payroll <payroll@syntaxasia.lk>

# ─── Application ─────────────────────────────────────────────────────────────
COMPANY_NAME=Syntax Asia
COMPANY_ADDRESS=No. 1 Example Road, Colombo 3
CURRENCY_SYMBOL=LKR
SESSION_IDLE_TIMEOUT=1800
EXCEL_UPLOAD_MAX_MB=5
EXCEL_MAX_ROWS=500

# ─── Error reporting (production) ────────────────────────────────────────────
ADMINS_EMAIL=admin@syntaxasia.lk
