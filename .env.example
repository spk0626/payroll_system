# ─── Core ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=replace-with-64-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# Optional for SQLite demos. On Render with a persistent disk, use /var/data/db.sqlite3.
SQLITE_DATABASE_PATH=db.sqlite3
DATABASE_URL=postgres://syntax_user:yourpassword@localhost:5432/syntax_asia_db
MEMCACHED_LOCATION=127.0.0.1:11211

# ─── Admin ───────────────────────────────────────────────────────────────────
# Change this from the default to obscure the admin panel from scanners
ADMIN_URL=management-portal/

# ─── Email ───────────────────────────────────────────────────────────────────
# Development default is console email. Use smtp backend when testing real email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=payroll@syntaxasia.lk
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Syntax Asia Payroll <payroll@syntaxasia.lk>

# ─── Application ─────────────────────────────────────────────────────────────
COMPANY_NAME=Syntax Asia
COMPANY_ADDRESS=No. 1 Example Road, Colombo 3
CURRENCY_SYMBOL=LKR
SITE_URL=http://localhost:8000
SESSION_IDLE_TIMEOUT=1800
EXCEL_UPLOAD_MAX_MB=5
EXCEL_MAX_ROWS=500

# ─── Error reporting (production) ────────────────────────────────────────────
ADMINS_EMAIL=admin@syntaxasia.lk
